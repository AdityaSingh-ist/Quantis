# ─────────────────────────────────────────────────────────────────────────────
# Quantis — Environment Variables Template
# Copy this file to ".env" and fill in your real values.
# NEVER commit .env — only commit .env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq AI ──────────────────────────────────────────────────────────────────
# Get your free key → https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your main Gmail password).
# How to generate:
#   1. Go to myaccount.google.com → Security
#   2. Enable "2-Step Verification" if not already on
#   3. Search "App passwords" in the search bar
#   4. App: Mail  |  Device: Other → name it "Quantis" → Generate
#   5. Copy the 16-character password shown (spaces are fine)
SENDER_EMAIL=your.email@gmail.com
SENDER_PASSWORD=your 16char app password here
