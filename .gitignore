# ─────────────────────────────────────────────────────────────────────────────
# Quantis .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# SECRETS — never commit these
.env
*.env
secrets.toml

# Streamlit local config
.streamlit/secrets.toml

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual environments
venv/
.venv/
env/
ENV/

# Temp files generated by Quantis
temp_quantis.csv
*.pdf

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
